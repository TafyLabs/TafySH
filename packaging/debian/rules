#!/usr/bin/make -f

export DH_VERBOSE = 1
export PYBUILD_NAME = tafysh

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	# Install shell completions
	install -D -m 644 debian/tafysh.bash-completion \
		debian/tafysh/usr/share/bash-completion/completions/tafysh
	install -D -m 644 completions/tafysh.zsh \
		debian/tafysh/usr/share/zsh/vendor-completions/_tafysh
	install -D -m 644 completions/tafysh.fish \
		debian/tafysh/usr/share/fish/vendor_completions.d/tafysh.fish

override_dh_installchangelogs:
	dh_installchangelogs CHANGELOG.md
