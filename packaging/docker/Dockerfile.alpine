# TafySH Alpine Docker Image (minimal)
#
# Build:
#   docker build -t tafysh:alpine -f Dockerfile.alpine .
#
# Run:
#   docker run -it --rm -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY tafysh:alpine

FROM python:3.11-alpine

LABEL org.opencontainers.image.title="TafySH (Alpine)"
LABEL org.opencontainers.image.description="AI-enhanced terminal shell - Alpine minimal image"
LABEL org.opencontainers.image.url="https://github.com/tafysh/tafysh"

# Install system dependencies
RUN apk add --no-cache \
    git \
    curl \
    wget \
    less \
    vim \
    jq \
    tree \
    ncurses \
    bash

# Set locale-related env vars
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV TERM=xterm-256color

# Create non-root user
RUN adduser -D -s /bin/sh tafysh

# Install TafySH
RUN pip install --no-cache-dir tafysh anthropic openai || pip install --no-cache-dir tafysh

# Add to /etc/shells
RUN echo "/usr/local/bin/tafysh" >> /etc/shells

# Set working directory
WORKDIR /home/tafysh

# Switch to non-root user
USER tafysh

# Create config directory
RUN mkdir -p /home/tafysh/.config/tafysh

# Set shell
ENV SHELL=/usr/local/bin/tafysh

# Default command
ENTRYPOINT ["/usr/local/bin/tafysh"]
